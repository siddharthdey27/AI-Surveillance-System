# ─────────────────────────────────────────────────────────────
# AI Surveillance System — Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────────

# ── Detection Settings ──────────────────────────────────────
YOLO_CONF=0.4                    # YOLO confidence threshold (0.1–1.0)
VIOLENCE_CONF=0.6                # Violence detection threshold (0.1–1.0)
FRAME_SKIP=2                     # Process every Nth frame (1=all, 2=half, etc.)
SAVE_SNAPSHOTS=true              # Save JPEG snapshots on detection

# ── Twilio SMS/MMS Notifications ────────────────────────────
# Sign up at https://www.twilio.com/try-twilio
TWILIO_ACCOUNT_SID=              # e.g., ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=               # e.g., xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_FROM=                     # Twilio phone number, e.g., +15551234567
TWILIO_TO=                       # Recipient phone number, e.g., +15559876543

# ── Telegram Bot Notifications ──────────────────────────────
# 1. Message @BotFather on Telegram → /newbot → get token
# 2. Send any message to the bot
# 3. Visit https://api.telegram.org/bot<TOKEN>/getUpdates to find chat_id
TELEGRAM_BOT_TOKEN=              # e.g., 123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
TELEGRAM_CHAT_ID=                # e.g., 123456789
